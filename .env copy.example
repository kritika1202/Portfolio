# EmailJS credentials — get these from https://emailjs.com
# 1. Create a free account
# 2. Add Service: Gmail — copy the Service ID
# 3. Create a Template with variables: {{name}}, {{email}}, {{message}}
# 4. Copy the Template ID and your Public Key (Account > API Keys)

VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxxxxx
VITE_EMAILJS_TEMPLATE_ID_REPLY=template_xxxxxxx